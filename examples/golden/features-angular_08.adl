# GOLDEN RVBF RCentral DISJOINT
# GROUND-TRUTH: dEta(jets[0],jets[1]) is the SIGNED difference (j0.eta - j1.eta).
#   (3,inf] and [-inf,1) cannot both hold -> disjoint.
#   In RVBF: {j0 eta4, j1 eta0}=dEta4. In RCentral: {j0 eta0, j1 eta0.5}=dEta-0.5. dEta2 in neither.

object jets
  take Jet
  select pt > 30

region RVBF
  select size(jets) >= 2
  select dEta(jets[0], jets[1]) > 3.0

region RCentral
  select size(jets) >= 2
  select dEta(jets[0], jets[1]) < 1.0
