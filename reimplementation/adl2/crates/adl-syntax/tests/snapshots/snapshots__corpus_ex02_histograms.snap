File
  Info name=analysis @16:1
    Line key=title value="\"ADL/CL ex2: Histograms in a simple semileptonic final state\""
  Object kw=object name=goodJets @20:1
    Take kw=take src=Jet @21:3
    Cut kw=select @22:3
      Cmp op=>
        Call name=pT
          Ident Jet
        Num 50
    Cut kw=select @23:3
      Cmp op=<
        Call name=abs
          Call name=eta
            Ident Jet
        Num 2.4
  Object kw=object name=goodbJets @25:1
    Take kw=take src=goodJets @26:3
